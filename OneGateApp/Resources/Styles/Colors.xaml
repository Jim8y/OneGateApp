<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit">

    <Color x:Key="White">#f1f3f6</Color>
    <Color x:Key="Black">#282b34</Color>
    <Color x:Key="Gray100">#E1E1E1</Color>
    <Color x:Key="Gray200">#C8C8C8</Color>
    <Color x:Key="Gray300">#ACACAC</Color>
    <Color x:Key="Gray400">#919191</Color>
    <Color x:Key="Gray500">#6E6E6E</Color>
    <Color x:Key="Gray600">#404040</Color>
    <Color x:Key="Gray900">#212121</Color>
    <Color x:Key="Gray950">#141414</Color>

    <toolkit:AppThemeColor x:Key="Primary" Light="{StaticResource Black}" Dark="{StaticResource White}" />
    <toolkit:AppThemeColor x:Key="Secondary" Default="#888a96" />
    <toolkit:AppThemeColor x:Key="Success" Default="#5bc782" />
    <toolkit:AppThemeColor x:Key="Danger" Default="#d63e49" />
    <toolkit:AppThemeColor x:Key="Accent" Light="{StaticResource White}" Dark="{StaticResource Black}" />
    <toolkit:AppThemeColor x:Key="Panel" Light="White" Dark="Black" />
    <toolkit:AppThemeColor x:Key="TextBox" Light="#e9eaee" Dark="#363B49" />

</ResourceDictionary>
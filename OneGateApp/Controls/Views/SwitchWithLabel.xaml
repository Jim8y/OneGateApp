<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:og="http://schemas.neoorder.org/onegate/controls"
             x:Class="NeoOrder.OneGate.Controls.Views.SwitchWithLabel">
    <HorizontalStackLayout BindingContext="{Binding Source={RelativeSource AncestorType={x:Type og:SwitchWithLabel}}}">
        <Switch IsToggled="{Binding IsToggled}" MinimumWidthRequest="0" VerticalOptions="Center" />
        <Label Text="{Binding Text}" VerticalOptions="Center">
            <Label.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnLabelTapped" />
            </Label.GestureRecognizers>
        </Label>
    </HorizontalStackLayout>
</ContentView>

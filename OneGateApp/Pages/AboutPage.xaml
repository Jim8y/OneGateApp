<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:og="http://schemas.neoorder.org/onegate/controls"
             x:Class="NeoOrder.OneGate.Pages.AboutPage"
             Title="{x:Static og:Strings.AboutOneGate}"
             BindingContext="{Binding Source={RelativeSource Self}}"
             Shell.TabBarIsVisible="False">
    <VerticalStackLayout Margin="20" Spacing="20">
        <Image Source="logo_vertical.png" WidthRequest="128" />
        <Label StyleClass="Secondary" Text="{Binding AppInfo.VersionString}" HorizontalOptions="Center" />
        <og:SettingsView Settings="{Binding SettingEntries}" />
    </VerticalStackLayout>
</ContentPage>
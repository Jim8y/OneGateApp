<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:og="http://schemas.neoorder.org/onegate/controls"
             x:Class="NeoOrder.OneGate.Pages.ChangeWalletNamePage"
             Title="{x:Static og:Strings.WalletName}"
             SafeAreaEdges="All"
             BindingContext="{Binding Source={RelativeSource Self}}"
             Shell.TabBarIsVisible="False">
    <Grid RowDefinitions="*,Auto" Margin="20">
        <VerticalStackLayout Spacing="20">
            <Label StyleClass="Secondary" Text="{x:Static og:Strings.WalletName}" />
            <Entry x:Name="entryWalletName" Text="{Binding Wallet.Name}" Margin="0,-20,0,0" />
            <og:ValidationMessage Title="{x:Static og:Strings.WalletName}" Margin="0,-20,0,0" Target="{x:Reference entryWalletName}">
                <og:Required />
            </og:ValidationMessage>
        </VerticalStackLayout>
        <og:Submit Grid.Row="1" Text="{x:Static og:Strings.OK}" Submitted="OnSubmitted" />
    </Grid>
</ContentPage>
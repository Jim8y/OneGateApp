<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:og="http://schemas.neoorder.org/onegate/controls"
             x:Class="NeoOrder.OneGate.Pages.DisableBiometricPage"
             Title="{x:Static og:Strings.DisableBiometric}"
             Shell.TabBarIsVisible="False">
    <Grid RowDefinitions="*,auto" Margin="20">
        <Label Text="{x:Static og:Strings.DisableBiometricText}" />
        <Button Grid.Row="1" Text="{x:Static og:Strings.DisableBiometric}" Clicked="OnDisableClicked" />
    </Grid>
</ContentPage>
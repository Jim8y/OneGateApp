<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:og="http://schemas.neoorder.org/onegate/controls"
             x:Class="NeoOrder.OneGate.Pages.AuthenticatePage"
             Title="{x:Static og:Strings.SignInWithNeo}"
             SafeAreaEdges="All"
             Shell.TabBarIsVisible="False">
    <Grid RowDefinitions="2*,*">
        <VerticalStackLayout Spacing="20" VerticalOptions="Center">
            <Label HorizontalOptions="Center">
                <Label.FormattedText>
                    <FormattedString>
                        <Span Text="{x:Static og:Strings.SigningIn}" />
                        <Span Text="…" />
                    </FormattedString>
                </Label.FormattedText>
            </Label>
            <ActivityIndicator IsRunning="True" />
        </VerticalStackLayout>
    </Grid>
</ContentPage>
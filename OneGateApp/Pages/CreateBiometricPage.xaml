<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:og="http://schemas.neoorder.org/onegate/controls"
             x:Class="NeoOrder.OneGate.Pages.CreateBiometricPage"
             Title="{x:Static og:Strings.CreateBiometricCredential}"
             BindingContext="{Binding Source={RelativeSource Self}}"
             Shell.TabBarIsVisible="False">
    <Grid RowDefinitions="*,Auto" Margin="20" RowSpacing="20">
        <VerticalStackLayout Spacing="20">
            <Label Text="{x:Static og:Strings.BiometricIntroductionText}" />
            <Label StyleClass="Secondary" Text="{x:Static og:Strings.VerifyPassword}" />
            <Entry x:Name="entryPassword" Text="{Binding Password}" IsPassword="True" Margin="0,-20,0,0" />
            <og:ValidationMessage x:Name="errMsg" Title="{x:Static og:Strings.Password}" Margin="0,-20,0,0" Target="{x:Reference entryPassword}">
                <og:Required />
            </og:ValidationMessage>
        </VerticalStackLayout>
        <og:Submit Grid.Row="1" Text="{x:Static og:Strings.CreateBiometricCredential}" Submitted="OnSubmitted" />
    </Grid>
</ContentPage>
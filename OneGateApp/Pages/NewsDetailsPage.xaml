<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:og="http://schemas.neoorder.org/onegate/controls"
             x:Class="NeoOrder.OneGate.Pages.NewsDetailsPage"
             x:DataType="og:News"
             Title="{Binding Title}"
             SafeAreaEdges="Container"
             Shell.TabBarIsVisible="False">
    <ContentPage.ToolbarItems>
        <ToolbarItem Order="Secondary" Text="{x:Static og:Strings.Share}" Command="{x:Static og:Commands.Share}" CommandParameter="{Binding .}" />
        <ToolbarItem Order="Secondary" Text="{x:Static og:Strings.ShowOriginalText}" Command="{x:Static og:Commands.OpenUrl}" CommandParameter="{Binding Url}" />
    </ContentPage.ToolbarItems>
    <WebView>
        <WebView.Source>
            <HtmlWebViewSource Html="{Binding ContentHtml}" />
        </WebView.Source>
    </WebView>
</ContentPage>